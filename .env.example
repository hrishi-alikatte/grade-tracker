# Notare — variables d'environnement (Vite).
# Copiez ce fichier en .env.local et renseignez les valeurs de VOTRE projet
# Supabase (Dashboard → Project Settings → API). SEULE la clé anon (publique)
# doit figurer côté client — jamais la clé service_role. La RLS protège les
# données.
#
# Sans ces variables, l'app fonctionne en mode 100% local (aucune synchro).

VITE_SUPABASE_URL=https://VOTRE-REF.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_publique
